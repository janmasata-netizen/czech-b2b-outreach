      "id": "wf06-0000-0000-0000-000000000007",
      "name": "QEV API Call",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [
        2040,
        120
      ]
    },
    {
      "parameters": {
        "mode": "runOnceForEachItem",
        "jsCode": "const result = $input.item.json;\nconst item   = $('Loop Candidates').item.json;\n\nconst catchAll   = result.catch_all  === 'true' || result.catch_all  === true;\nconst mxFound    = result.mx_found   === 'true' || result.mx_found   === true;\nconst disposable = result.disposable === 'true' || result.disposable === true;\n\n// Catch-all: domain is real + MX valid + not disposable, but specific mailbox unconfirmable\nconst isCatchAll = result.result === 'risky' && catchAll && mxFound && !disposable;\nconst isValid    = result.result === 'valid';   // only genuinely confirmed mailboxes\nconst isInvalid  = result.result === 'invalid';\n\n// Pattern rank label for catch-all confidence display\nlet catchAllConfidence = null;\nif (isCatchAll) {\n  function norm(s) { return (s||'').toLowerCase().replace(/[^a-z0-9]/g,''); }\n  const f  = norm(item.first_name), l = norm(item.last_name);\n  const fi = f[0]||'', li = l[0]||'';\n  const local = item.email_address.split('@')[0];\n  const rank =\n    local===`${f}.${l}`    ? '1 - first.last'  :\n    local===`${fi}.${l}`   ? '2 - f.last'       :\n    local===`${f}${l}`     ? '3 - firstlast'    :\n    local===`${l}.${f}`    ? '4 - last.first'   :\n    local===`${l}${fi}`    ? '5 - lastf'        :\n    local===f              ? '6 - first'        :\n    local===l              ? '7 - last'         :\n    local===`${fi}${l}`    ? '8 - flast'        :\n    local===`${f}.${li}`   ? '9 - first.l'      :\n    local===`${fi}.${li}`  ? '10 - f.l'         : '11 - other';\n  catchAllConfidence = rank;\n}\n\nreturn { json: {\n  id:                   item.id,\n  qev_status:           isValid ? 'valid' : isCatchAll ? 'catch_all' : isInvalid ? 'invalid' : 'unknown',\n  is_verified:          isValid,\n  is_catch_all:         isCatchAll,\n  catch_all_confidence: catchAllConfidence,\n  lead_id:              item.lead_id,\n}};"
      },
