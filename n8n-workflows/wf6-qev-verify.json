    {
      "parameters": {
        "mode": "runOnceForAllItems",
        "jsCode": "const items   = $input.all().map(i => i.json);\nconst lead_id = $('Extract Lead ID').first().json.lead_id;\n\nconst mine = items.filter(c => {\n  const j = Array.isArray(c.jednatels) ? c.jednatels[0] : c.jednatels;\n  return j?.lead_id === lead_id;\n});\n\nconst hasVerified = mine.some(c => c.is_verified === true);\nconst hasCatchAll = mine.some(c => c.is_catch_all === true);\n\nconst bestVerified = mine.find(c => c.is_verified && c.type === 'jednatel')\n  || mine.find(c => c.is_verified);\nconst bestVerifiedType = bestVerified?.type || null;\n\nreturn [{ json: {\n  lead_id,\n  has_verified:             hasVerified,\n  has_catch_all_candidates: hasCatchAll,\n  best_verified_type:       bestVerifiedType,\n} }];"
      },
