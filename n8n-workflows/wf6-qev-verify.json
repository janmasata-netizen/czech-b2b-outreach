      "id": "wf06-conf-qev-00000-000000000001",
      "name": "Get Config QEV",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [
        720,
        300
      ]
    },
    {
      "parameters": {
        "mode": "runOnceForAllItems",
        "jsCode": "const entries = $input.all().map(i => i.json);\nconst keys = ['qev_api_key_1', 'qev_api_key_2', 'qev_api_key_3']\n  .map(k => entries.find(e => e.key === k)?.value)\n  .filter(v => v && v !== 'PLACEHOLDER' && v.trim() !== '');\nif (keys.length === 0) return [{ json: { qev_key: '' } }];\nconst qev_key = keys[Math.floor(Math.random() * keys.length)];\nreturn [{ json: { qev_key } }];"
      },
      "id": "wf06-0000-0000-0000-000000000017",
      "name": "Pick QEV Key",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        960,
        120
      ]
    },
    {
      "parameters": {
        "mode": "runOnceForAllItems",
        "jsCode": "const candidates = $('Get Likely Valid Candidates').all().map(i => i.json);\nconst lead_id = $('Extract Lead ID').first().json.lead_id;\n\nconst filtered = candidates.filter(c => {\n  const j = c.jednatels;\n  return j && (Array.isArray(j) ? j.some(x => x.lead_id === lead_id) : j.lead_id === lead_id);\n});\n\nreturn filtered.map(c => ({\n  json: {\n    id:            c.id,\n    email_address: c.email_address,\n    lead_id,\n    jednatel_id:   c.jednatel_id,\n    source:        c.source || 'combo_generation',\n    first_name:    c.jednatels?.[0]?.first_name ?? (c.jednatels?.first_name ?? ''),\n    last_name:     c.jednatels?.[0]?.last_name  ?? (c.jednatels?.last_name  ?? ''),\n  }\n}));"
      },
      "id": "wf06-0000-0000-0000-000000000004",
      "name": "Flatten Candidates",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        960,
        300
