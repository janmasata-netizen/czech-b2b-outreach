{
  "name": "WF10: Daily Gmail Counter Reset",
  "nodes": [
    {
      "parameters": {
        "rule": {
          "interval": [
            {
              "field": "cronExpression",
              "expression": "0 0 * * *"
            }
          ]
        }
      },
      "id": "wf10-0000-0000-0000-000000000001",
      "name": "Daily Midnight",
      "type": "n8n-nodes-base.scheduleTrigger",
      "typeVersion": 1.1,
      "position": [0, 300]
    },
    {
      "parameters": {
        "method": "POST",
        "url": "https://cycapkswtucbucyegdsn.supabase.co/rest/v1/rpc/reset_daily_sends",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            {
              "name": "apikey",
              "value": "SUPABASE_SERVICE_ROLE_KEY_PLACEHOLDER"
            },
            {
              "name": "Authorization",
              "value": "Bearer SUPABASE_SERVICE_ROLE_KEY_PLACEHOLDER"
            },
            {
              "name": "Content-Type",
              "value": "application/json"
            }
          ]
        },
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "{}",
        "options": {
          "timeout": 30000,
          "neverError": true
        }
      },
      "id": "wf10-0000-0000-0000-000000000002",
      "name": "Reset Daily Sends RPC",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [240, 300]
    },
    {
      "parameters": {
        "mode": "runOnceForEachItem",
        "jsCode": "console.log(\"[WF10] Daily sends reset at\", new Date().toISOString());\nreturn { json: { reset_completed_at: new Date().toISOString(), success: true } };"
      },
      "id": "wf10-0000-0000-0000-000000000003",
      "name": "Log Reset Complete",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [480, 300]
    },
    {
      "parameters": {
        "method": "DELETE",
        "url": "={{ 'https://cycapkswtucbucyegdsn.supabase.co/rest/v1/email_probe_bounces?created_at=lt.' + new Date(Date.now() - 86400000).toISOString() }}",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            {
              "name": "apikey",
              "value": "SUPABASE_SERVICE_ROLE_KEY_PLACEHOLDER"
            },
            {
              "name": "Authorization",
              "value": "Bearer SUPABASE_SERVICE_ROLE_KEY_PLACEHOLDER"
            },
            {
              "name": "Prefer",
              "value": "return=minimal"
            }
          ]
        },
        "options": {
          "timeout": 30000,
          "neverError": true
        }
      },
      "id": "wf10-0000-0000-0000-000000000004",
      "name": "Delete Old Bounce Rows",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [720, 300]
    },
    {
      "parameters": {
        "method": "DELETE",
        "url": "={{ 'https://cycapkswtucbucyegdsn.supabase.co/rest/v1/processed_reply_emails?processed_at=lt.' + new Date(Date.now() - 7 * 86400000).toISOString() }}",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            {
              "name": "apikey",
              "value": "SUPABASE_SERVICE_ROLE_KEY_PLACEHOLDER"
            },
            {
              "name": "Authorization",
              "value": "Bearer SUPABASE_SERVICE_ROLE_KEY_PLACEHOLDER"
            },
            {
              "name": "Prefer",
              "value": "return=minimal"
            }
          ]
        },
        "options": {
          "timeout": 30000,
          "neverError": true
        }
      },
      "id": "wf10-0000-0000-0000-000000000005",
      "name": "Delete Old Processed Replies",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [960, 300]
    },
    {
      "parameters": {
        "method": "DELETE",
        "url": "={{ 'https://cycapkswtucbucyegdsn.supabase.co/rest/v1/unmatched_replies?created_at=lt.' + new Date(Date.now() - 30 * 86400000).toISOString() }}",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            {
              "name": "apikey",
              "value": "SUPABASE_SERVICE_ROLE_KEY_PLACEHOLDER"
            },
            {
              "name": "Authorization",
              "value": "Bearer SUPABASE_SERVICE_ROLE_KEY_PLACEHOLDER"
            },
            {
              "name": "Prefer",
              "value": "return=minimal"
            }
          ]
        },
        "options": {
          "timeout": 30000,
          "neverError": true
        }
      },
      "id": "wf10-0000-0000-0000-000000000006",
      "name": "Delete Old Unmatched Replies",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [1200, 300]
    }
  ],
  "connections": {
    "Daily Midnight": {
      "main": [
        [
          {
            "node": "Reset Daily Sends RPC",
            "type": "main",
            "index": 0
          }
        ]
      ]
    },
    "Reset Daily Sends RPC": {
      "main": [
        [
          {
            "node": "Log Reset Complete",
            "type": "main",
            "index": 0
          }
        ]
      ]
    },
    "Log Reset Complete": {
      "main": [
        [
          {
            "node": "Delete Old Bounce Rows",
            "type": "main",
            "index": 0
          }
        ]
      ]
    },
    "Delete Old Bounce Rows": {
      "main": [
        [
          {
            "node": "Delete Old Processed Replies",
            "type": "main",
            "index": 0
          }
        ]
      ]
    }
  },
  "active": false,
  "settings": {
    "executionOrder": "v1"
  },
  "pinData": {}
}
