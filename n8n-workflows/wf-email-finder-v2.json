        "jsCode": "// Anchor item — always outputs 1 item with candidates+domain so Merge Recheck is never starved\nconst inputData = $('Extract & Normalize Input').first().json;\nreturn [{ json: { candidates: inputData.candidates || [], domain: inputData.domain } }];"
