      "parameters": {
        "mode": "runOnceForAllItems",
        "jsCode": "const smtpData = $input.first().json;\nconst domain = smtpData.domain;\nconst candidates = smtpData.candidates || [];\nconst mode = $('Extract & Normalize Input').first().json.mode;\n\nconst results = candidates.map(c => ({\n  email: c.email,\n  status: c.accepted ? 'valid' : 'invalid',\n  confidence: 'high',\n  smtp_result: String(c.code || 0),\n  method: 'smtp'\n}));\n\nconst filtered = mode === 'name' ? results.filter(r => r.status === 'valid') : results;\n\nreturn [{ json: { candidates: filtered, domain, total: filtered.length, method: 'smtp' } }];"
      },
