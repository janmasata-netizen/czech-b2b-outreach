    {
      "parameters": {
        "mode": "runOnceForAllItems",
        "jsCode": "// Input 0 (Recheck Anchor): { candidates, domain } — always 1 item\n// Input 1 (Query Bounces Recheck): 0..N items with { bounced_email }\nconst allItems = $input.all().map(function(i) { return i.json; });\n\nconst bouncedSet = new Set(\n  allItems\n    .filter(function(r) { return r.bounced_email; })\n    .map(function(r) { return r.bounced_email.toLowerCase(); })\n);\n\nconst anchorData = $('Recheck Anchor').first().json;\nconst candidates = anchorData.candidates || [];\nconst domain = anchorData.domain;\n\nconst results = candidates.map(function(email) {\n  return {\n    email: email,\n    status:      bouncedSet.has(email.toLowerCase()) ? 'invalid'      : 'likely_valid',\n    confidence:  bouncedSet.has(email.toLowerCase()) ? 'high'         : 'medium',\n    smtp_result: bouncedSet.has(email.toLowerCase()) ? 'bounced'      : 'no_bounce',\n    method: 'probe'\n  };\n});\n\nresults.sort(function(a, b) { return a.status === 'likely_valid' ? -1 : 1; });\n\nreturn [{ json: { candidates: results, domain: domain, total: results.length, method: 'probe' } }];"
      },
