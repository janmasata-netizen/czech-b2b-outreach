        "mode": "runOnceForAllItems",
        "jsCode": "const data = $('Parse Contacts').first().json;\nconst contacts = JSON.parse(data.contacts || '[]');\n\n// Pass through names — DB trigger generates salutation automatically\nconst items = contacts.map(j => ({\n  company_id: $('Get Lead Company ID').first().json.company_id || $('Get Lead Company ID').first().json[0]?.company_id,\n  full_name: j.full_name,\n  first_name: j.first_name,\n  last_name: j.last_name\n}));\n\nreturn { json: { lead_id: data.lead_id, ico: data.ico, contacts_body: JSON.stringify(items), contacts_count: items.length } };"
