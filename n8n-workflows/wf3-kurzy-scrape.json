      "id": "wf03-0000-0000-0000-000000000004",
      "name": "Fetch Kurzy Page",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [960, 300]
    },
    {
      "parameters": {
        "mode": "runOnceForEachItem",
        "jsCode": "const lead_id = $('Extract Params').first().json.lead_id;\nconst ico = $('Extract Params').first().json.ico;\nconst leadData = $('Get Lead Company ID').first().json;\nconst existingDomain = (leadData.domain || leadData.website || '').replace(/^https?:\\/\\/(www\\.)?/, '').replace(/\\/.*$/, '').trim();\n\nconst resp = $input.item.json;\nconst html = (resp.body || resp.data || '') + '';\n\nif (!html || html.length < 100) {\n  return { json: { lead_id, ico, contacts: '[]', has_contacts: false, parse_error: 'Empty or invalid HTML', kurzy_website: '', has_existing_domain: !!existingDomain } };\n}\n\nconst contacts = [];\nconst seen = new Set();\n\n// Strategy 1: Kurzy.cz structure — <b>Jednatel</b> then <a href=\"/osoba/N/\">NAME</a>\nconst kurzyPattern = /<(?:b|strong)[^>]*>[\\s\\n]*Jednatel[\\s\\n]*<\\/(?:b|strong)>[\\s\\S]{0,600}?<a[^>]*href=\"\\/osoba\\/\\d+\\/[^\"]*\"[^>]*>([^<]+)/gi;\nlet m;\nwhile ((m = kurzyPattern.exec(html)) !== null) {\n  const raw = m[1].trim();\n  if (raw.length < 3 || raw.length > 100 || seen.has(raw.toLowerCase())) continue;\n  seen.add(raw.toLowerCase());\n  const cleaned = raw.replace(/^(Ing\\.|Mgr\\.|Bc\\.|JUDr\\.|MUDr\\.|PhDr\\.|Doc\\.|Prof\\.|RNDr\\.|DiS\\.)\\s*/gi, '').trim();\n  const parts = cleaned.split(/\\s+/);\n  if (parts.length < 2) continue;\n  contacts.push({ full_name: raw, first_name: parts[0], last_name: parts[parts.length - 1] });\n}\n\n// Strategy 2: generic TD pattern\nif (contacts.length === 0) {\n  const tdPattern = /<td[^>]*>[^<]*jednatel[^<]*<\\/td>\\s*<td[^>]*>([^<]+)<\\/td>/gi;\n  while ((m = tdPattern.exec(html)) !== null) {\n    const raw = m[1].trim();\n    if (raw.length < 3 || raw.length > 100 || seen.has(raw.toLowerCase())) continue;\n    seen.add(raw.toLowerCase());\n    const cleaned = raw.replace(/^(Ing\\.|Mgr\\.|Bc\\.|JUDr\\.|MUDr\\.|PhDr\\.)\\s*/gi, '').trim();\n    const parts = cleaned.split(/\\s+/);\n    if (parts.length < 2) continue;\n    contacts.push({ full_name: raw, first_name: parts[0], last_name: parts[parts.length - 1] });\n  }\n}\n\n// Strategy 3: Statutární orgán section\nif (contacts.length === 0) {\n  const sectionMatch = html.match(/Statutárn[íi] orgán[\\s\\S]*?(?=<h[1-4]|<\\/section)/i);\n  if (sectionMatch) {\n    const section = sectionMatch[0];\n    const namePattern = /<strong>([^<]{5,60})<\\/strong>/g;\n    while ((m = namePattern.exec(section)) !== null) {\n      const raw = m[1].trim();\n      if (seen.has(raw.toLowerCase())) continue;\n      seen.add(raw.toLowerCase());\n      const cleaned = raw.replace(/^(Ing\\.|Mgr\\.|Bc\\.|JUDr\\.|MUDr\\.)\\s*/gi, '').trim();\n      const parts = cleaned.split(/\\s+/);\n      if (parts.length < 2) continue;\n      contacts.push({ full_name: raw, first_name: parts[0], last_name: parts[parts.length - 1] });\n    }\n    if (contacts.length === 0) {\n      const osobaPattern = /<a[^>]*href=\"\\/osoba\\/\\d+\\/[^\"]*\"[^>]*>([^<]+)<\\/a>/gi;\n      while ((m = osobaPattern.exec(section)) !== null) {\n        const raw = m[1].trim();\n        if (raw.length < 3 || raw.length > 100 || seen.has(raw.toLowerCase())) continue;\n        seen.add(raw.toLowerCase());\n        const cleaned = raw.replace(/^(Ing\\.|Mgr\\.|Bc\\.|JUDr\\.|MUDr\\.|PhDr\\.|Doc\\.|Prof\\.|RNDr\\.|DiS\\.)\\s*/gi, '').trim();\n        const parts = cleaned.split(/\\s+/);\n        if (parts.length < 2) continue;\n        contacts.push({ full_name: raw, first_name: parts[0], last_name: parts[parts.length - 1] });\n      }\n    }\n  }\n}\n\n// Extract website from Kurzy.cz HTML if lead has no domain yet\nlet kurzy_website = '';\nif (!existingDomain) {\n  // Look for website in WWW row: <td><b>WWW:</b></td><td><a href=\"...\">\n  const SITE_BL = new Set(['kurzy.cz','rejstrik-firem.kurzy.cz','rejstrik.penize.cz','or.justice.cz','justice.cz','google.com','google.cz','facebook.com','linkedin.com','instagram.com','twitter.com','x.com','youtube.com','mapy.cz','firmy.cz','hbi.cz','detail.cz','databaze-firem.cz','wikipedia.org','seznam.cz','idnes.cz','novinky.cz','aktualne.cz']);\n  function isSiteBL(d) { if (!d) return true; if (SITE_BL.has(d)) return true; var p = d.split('.'); return p.length > 2 && SITE_BL.has(p.slice(-2).join('.')); }\n  var webMatch = html.match(/WWW:<\\/b><\\/td>\\s*<td[^>]*>\\s*<a[^>]*href=\"(https?:\\/\\/[^\"]+)\"/i);\n  if (webMatch) {\n    var url = webMatch[1];\n    var d = url.replace(/^https?:\\/\\//i, '').replace(/^www\\./i, '').split(/[\\/?#]/)[0].toLowerCase();\n    if (d && /^[a-z0-9.-]+\\.[a-z]{2,}$/.test(d) && !isSiteBL(d)) {\n      kurzy_website = d;\n    }\n  }\n  // Fallback: look for any external URL in the page\n  if (!kurzy_website) {\n    var extMatch = html.match(/href=\"(https?:\\/\\/(?:www\\.)?([a-z0-9.-]+\\.[a-z]{2,}))[^\"]*\"/i);\n    if (extMatch && extMatch[2]) {\n      var fd = extMatch[2].toLowerCase();\n      if (!isSiteBL(fd)) {\n        kurzy_website = fd;\n      }\n    }\n  }\n}\n\nreturn { json: { lead_id, ico, contacts: JSON.stringify(contacts), has_contacts: contacts.length > 0, kurzy_website, has_existing_domain: !!existingDomain } };"
      },
