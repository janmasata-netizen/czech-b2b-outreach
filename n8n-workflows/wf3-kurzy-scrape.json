        "jsCode": "const data = $input.first().json;\nconst jednatels = JSON.parse(data.jednatels || '[]');\n\n// Pass through names — DB trigger generates salutation automatically\nconst items = jednatels.map(j => ({\n  lead_id: data.lead_id,\n  full_name: j.full_name,\n  first_name: j.first_name,\n  last_name: j.last_name\n}));\n\nreturn { json: { lead_id: data.lead_id, ico: data.ico, jednatels_body: JSON.stringify(items), jednatels_count: items.length } };"
      },
