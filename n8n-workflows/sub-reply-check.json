        "jsCode": "const items = $input.all().map(i => i.json);\nconst waveLead = items.find(wl => wl && wl.id) || null;\nconst prev = $('Check Lead Found').first().json;\nreturn [{ json: {\n  ...prev,\n  wave_lead_id: waveLead ? waveLead.id : null,\n  wave_id: waveLead ? waveLead.wave_id : null,\n  has_wave_lead: !!waveLead\n}}];"
      },
