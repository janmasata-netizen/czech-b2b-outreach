      "id": "src-0000-0000-0000-000000000043",
      "name": "Fuzzy Domain Candidates",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [4200, 480]
    },
    {
      "parameters": {
        "mode": "runOnceForAllItems",
        "jsCode": "const candidates = $input.all().map(i => i.json).filter(l => l && l.id);\nconst prev = $('Extract Sender Domain').first().json;\nconst senderDomain = prev.sender_domain;\n\nif (candidates.length === 0) {\n  return [{ json: { ...prev, lead_found: false, match_method: 'none' } }];\n}\n\nfunction rootDomain(d) {\n  return (d || '').replace(/\\.[a-z]{2,}$/i, '').replace(/^(www\\.)?/, '').toLowerCase();\n}\n\nfunction levenshtein(a, b) {\n  const m = a.length, n = b.length;\n  const dp = Array.from({ length: m + 1 }, () => new Array(n + 1).fill(0));\n  for (let i = 0; i <= m; i++) dp[i][0] = i;\n  for (let j = 0; j <= n; j++) dp[0][j] = j;\n  for (let i = 1; i <= m; i++) {\n    for (let j = 1; j <= n; j++) {\n      dp[i][j] = Math.min(\n        dp[i-1][j] + 1,\n        dp[i][j-1] + 1,\n        dp[i-1][j-1] + (a[i-1] !== b[j-1] ? 1 : 0)\n      );\n    }\n  }\n  return dp[m][n];\n}\n\nconst senderRoot = rootDomain(senderDomain);\nlet bestMatch = null;\nlet bestScore = 0;\n\nfor (const lead of candidates) {\n  const leadDomain = (lead.domain || '').toLowerCase();\n  const leadRoot = rootDomain(leadDomain);\n  let score = 0;\n  if (senderDomain.includes(leadDomain) || leadDomain.includes(senderDomain)) score += 3;\n  if (senderRoot.includes(leadRoot) || leadRoot.includes(senderRoot)) score += 2;\n  if (senderRoot === leadRoot && senderRoot.length >= 3) score += 5;\n  const dist = levenshtein(senderDomain, leadDomain);\n  if (dist <= 2) score += (3 - dist);\n  if (score > bestScore) {\n    bestScore = score;\n    bestMatch = lead;\n  }\n}\n\nif (bestMatch && bestScore >= 2) {\n  return [{ json: {\n    lead_found: true,\n    lead_id: bestMatch.id,\n    lead_status: bestMatch.status,\n    match_method: 'fuzzy',\n    from_email: prev.from_email,\n    sender_domain: prev.sender_domain,\n    subject: prev.subject,\n    body_preview: prev.body_preview,\n    received_at: prev.received_at,\n    salesman_id: prev.salesman_id\n  }}];\n}\n\nreturn [{ json: { ...prev, lead_found: false, match_method: 'none' } }];"
      },
