            { "name": "domain", "value": "={{ 'ilike.%' + $json.sender_domain.replace(/\\.[a-z]{2,}$/i, '').replace(/^(www\\.)?/, '') + '%' }}" },
            { "name": "is_active", "value": "eq.true" },
