      "id": "wf02-0000-0000-0000-000000000006",
      "name": "ARES API Search",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [
        1200,
        300
      ]
    },
    {
      "parameters": {
        "mode": "runOnceForEachItem",
        "jsCode": "const resp = $input.item.json;\nconst lead = $('Extract Lead').first().json;\nconst body = resp.body || resp;\nconst raw = body.ekonomickeSubjekty || [];\nif (raw.length === 0) {\n  if (lead.ico) return { json: { has_results: true, ico: lead.ico, lead_id: lead.lead_id,\n    company_id: lead.company_id, company_name: lead.company_name } };\n  return { json: { has_results: false, lead_id: lead.lead_id,\n    company_id: lead.company_id, company_name: lead.company_name, ico: null } };\n}\n// Find best match by company name\nconst companyName = (lead.company_name || '').toLowerCase();\nlet best = raw[0];\nlet bestScore = 0;\nfor (const r of raw) {\n  const name = (r.obchodniJmeno || '').toLowerCase();\n  let score = name === companyName ? 100 : name.includes(companyName) ? 50 : companyName.includes(name) ? 30 : 0;\n  if (score > bestScore) { bestScore = score; best = r; }\n}\n// Validate ico field — fall back to DB-stored ICO if ARES result has no ico\nconst rawIco = best.ico;\nif (!rawIco) {\n  if (lead.ico) return { json: { has_results: true, ico: lead.ico, lead_id: lead.lead_id,\n    company_id: lead.company_id, company_name: lead.company_name } };\n  return { json: { has_results: false, lead_id: lead.lead_id,\n    company_id: lead.company_id, company_name: lead.company_name, ico: null } };\n}\nconst ico = String(rawIco).padStart(8, '0');\nreturn { json: { has_results: true, ico, lead_id: lead.lead_id,\n    company_id: lead.company_id, company_name: lead.company_name } };"
      },
