      "id": "wf02-0000-0000-0000-000000000015",
      "name": "ARES VR Lookup",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [
        2160,
        180
      ]
    },
    {
      "parameters": {
        "mode": "runOnceForEachItem",
        "jsCode": "const vrResp = $input.item.json;\nconst lead = $('Best Match ICO').first().json;\nconst contacts = [];\nconst seen = new Set();\n\ntry {\n  const data = vrResp || {};\n  const organs = data.statutarniOrgan || [];\n  for (const organ of organs) {\n    const members = organ.clenove || [];\n    for (const member of members) {\n      const fo = member.fyzickaOsoba || {};\n      const jmeno = (fo.jmeno || '').trim();\n      const prijmeni = (fo.prijmeni || '').trim();\n      if (!jmeno || !prijmeni) continue;\n      const fullName = jmeno + ' ' + prijmeni;\n      const key = fullName.toLowerCase();\n      if (seen.has(key)) continue;\n      seen.add(key);\n      contacts.push({\n        company_id: lead.company_id,\n    company_id: lead.company_id,\n        full_name: fullName,\n        source: 'ares_vr'\n      });\n    }\n  }\n} catch(e) {\n  // VR returned error/404 — no contacts to extract\n}\n\nreturn { json: { contacts, company_id: lead.company_id,\n    company_id: lead.company_id, ico: lead.ico, company_name: lead.company_name } };"
      },
