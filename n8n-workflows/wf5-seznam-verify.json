            }
          ]
        },
        "sendQuery": true,
        "queryParameters": {
          "parameters": [
            {
              "name": "contact_id",
              "value": "={{ 'in.(' + $json.contact_ids.join(',') + ')' }}"
            },
            {
              "name": "seznam_status",
              "value": "eq.pending"
            },
            {
              "name": "select",
              "value": "id,email_address,contact_id"
            }
          ]
        },
        "options": {
          "timeout": 30000,
          "neverError": true
        }
      },
