    {
      "parameters": {
        "method": "GET",
        "url": "https://cycapkswtucbucyegdsn.supabase.co/rest/v1/config",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            {
              "name": "apikey",
              "value": "SUPABASE_SERVICE_ROLE_KEY_PLACEHOLDER"
            },
            {
              "name": "Authorization",
              "value": "Bearer SUPABASE_SERVICE_ROLE_KEY_PLACEHOLDER"
            }
          ]
        },
        "sendQuery": true,
        "queryParameters": {
          "parameters": [
            {
              "name": "key",
              "value": "in.(seznam_from_email,qev_api_key_1,qev_api_key_2,qev_api_key_3)"
            },
            {
              "name": "select",
              "value": "key,value"
            }
          ]
        },
        "options": {
          "timeout": 30000,
          "neverError": true
        }
      },
      "id": "wf05c-n03",
      "name": "Get Config",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [
        480,
        300
      ]
    },
    {
      "parameters": {
        "mode": "runOnceForAllItems",
        "jsCode": "const rows = $input.all().map(i => i.json);\nconst get = k => rows.find(r => r.key === k)?.value ?? '';\nconst lead_id = $('Extract Lead ID').first().json.lead_id;\nconst keys = ['qev_api_key_1','qev_api_key_2','qev_api_key_3']\n  .map(k => get(k)).filter(v => v && v !== 'PLACEHOLDER');\nconst qev_key = keys.length > 0 ? keys[Math.floor(Math.random()*keys.length)] : '';\nreturn [{ json: { seznam_from_email: get('seznam_from_email'), qev_key, lead_id } }];"
      },
      "id": "wf05c-n04",
      "name": "Extract Config",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        720,
        300
      ]
    },
    {
      "parameters": {
        "resource": "row",
        "operation": "getAll",
        "tableId": "contacts",
        "returnAll": true,
        "filters": {
          "conditions": [
            {
              "condition": "eq",
              "keyName": "lead_id",
              "keyValue": "={{ $('Extract Lead ID').first().json.lead_id }}"
            }
          ]
        }
      },
      "id": "wf05c-n05",
      "name": "Get Contacts",
      "type": "n8n-nodes-base.supabase",
      "typeVersion": 1,
      "position": [
        960,
        300
      ],
      "credentials": {
        "supabaseApi": {
          "id": "8fUZtVEFmt5y101f",
          "name": "Supabase"
        }
      }
    },
    {
      "parameters": {
        "mode": "runOnceForAllItems",
        "jsCode": "const ids = $input.all().map(i => i.json.id).filter(Boolean);\nconst cfg = $('Extract Config').first().json;\nreturn [{ json: { contact_ids: ids, seznam_from_email: cfg.seznam_from_email, qev_key: cfg.qev_key, lead_id: cfg.lead_id } }];"
      },
      "id": "wf05c-n06",
