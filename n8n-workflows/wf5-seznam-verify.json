    {
      "parameters": {
        "mode": "runOnceForAllItems",
        "jsCode": "const all = $('Evaluate QEV').all().map(i => i.json);\nconst lead_id = $('Extract Lead ID').first().json.lead_id;\nconst verified = all.filter(i => i.is_verified === true);\nreturn [{ json: { has_verified: verified.length > 0, verified_count: verified.length, lead_id } }];"
      },
