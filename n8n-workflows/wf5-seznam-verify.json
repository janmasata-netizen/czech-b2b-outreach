        "jsCode": "const cfg = $('Build Contact IDs').first().json;\nreturn $input.all().map(i => ({ json: {\n  ...i.json,\n  seznam_from_email: cfg.seznam_from_email,\n  qev_key: cfg.qev_key,\n  lead_id: cfg.lead_id\n} }));"
      },
      "id": "wf05c-n08",
      "name": "Add Config",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        1680,
        300
      ]
    },
    {
