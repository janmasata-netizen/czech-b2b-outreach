    {
      "parameters": {
        "mode": "runOnceForEachItem",
        "jsCode": "const resp = $input.item.json;\nconst cand = $('Prepare QEV Items').item.json;\nconst isValid = resp.result === 'valid' && resp.safe_to_send === true;\nreturn { json: {\n  id: cand.id,\n  email_address: cand.email_address,\n  lead_id: cand.lead_id,\n  qev_status: isValid ? 'valid' : (resp.result === 'invalid' ? 'invalid' : 'unknown'),\n  is_verified: isValid\n} };"
      },
      "id": "wf05c-n20",
      "name": "Evaluate QEV",
      "type": "n8n-nodes-base.code",
