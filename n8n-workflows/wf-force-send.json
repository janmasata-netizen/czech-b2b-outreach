    {
      "parameters": {
        "mode": "runOnceForAllItems",
        "jsCode": "const items = $input.all().map(i => i.json);\n\n// Filter out wrapper objects (HTTP response metadata)\nconst emails = items.filter(eq => eq.id && eq.wave_lead_id);\n\nif (emails.length === 0) {\n  return [{ json: { has_emails: false, success: false, error: 'No eligible queue items found (all already sent or cancelled)' } }];\n}\n\nreturn emails.map(eq => ({ json: {\n  has_emails: true,\n  id:                  eq.id,\n  wave_lead_id:        eq.wave_lead_id,\n  jednatel_id:         eq.jednatel_id,\n  email_address:       eq.email_address,\n  sequence_number:     eq.sequence_number,\n  outreach_account_id: eq.outreach_account_id,\n  smtp_message_id_ref: eq.smtp_message_id_ref,\n  subject_rendered:    eq.subject_rendered,\n  body_rendered:       eq.body_rendered,\n  original_status:     eq.status,\n  thread_subject:      eq.thread_subject || '',\n  max_sequence_number: eq.max_sequence_number || 3,\n  retry_count:         0,\n} }));"
      },
